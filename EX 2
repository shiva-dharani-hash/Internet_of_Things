#include<HX711_ADC.h>
#include<Wire.h>
HX711_ADC LoadCell(4,5);
void setup() {
  Serial.begin(9600);
  LoadCell.begin();
  LoadCell.start(2000);
  LoadCell.setCalFactor(999.0);
}
void loop() {
  LoadCell.update();
  float i=LoadCell.getData();
  Serial.println(i);
}

  
  

  
  

