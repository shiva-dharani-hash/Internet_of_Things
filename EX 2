const int SoilPin=A0;
const int ledpin=6;

void setup() {
  Serial.begin(9600);
  pinMode(ledpin,OUTPUT);  
}

void loop() {
  int SoilMoisture=analogRead(SoilPin);
  Serial.print("Moisture Level:");
  Serial.println(SoilMoisture);
  if(SoilMoisture<220)
  digitalWrite(ledpin,HIGH);
  else
  digitalWrite(ledpin,LOW);
  delay(5000);
}

